<!DOCTYPE html>
<html lang="en-US">
<head>
    <title>Control Service</title>
    {{> control/partials/head-includes }}
</head>
<body>
{{> control/partials/nav}}
<div class="container">
    <h1 class="my-3">Random Exploration: Suggestion Queue</h1>
    <p class="text-muted">
        User-submitted domains awaiting review. Approving adds the domain to the
        live random exploration set; rejecting discards the suggestion (the same
        domain may be re-suggested later).
    </p>

    {{#if hasSuggestions}}
    <form method="POST">
    <table class="table">
        <tr>
            <th>Select</th>
            <th>Domain Name</th>
            <th>Suggested</th>
            <th>Screenshot</th>
        </tr>
        {{#each suggestions}}
        <tr>
            <td>
                <input type="checkbox" name="domain-{{id}}" id="domain-{{id}}"/>
                <label for="domain-{{id}}">Select</label>
            </td>
            <td>
                <a href="https://{{domainName}}">{{domainName}}</a>
            </td>
            <td>{{suggestedAt}}</td>
            <td>
                <img src="/screenshot/{{id}}" style="max-width: 100%; max-height: 100px"/>
            </td>
        </tr>
        {{/each}}
        <tr>
            <td colspan="4">
                <button type="submit" formaction="/random-domains/suggestions/approve" class="btn btn-primary">Approve selected</button>
                <button type="submit" formaction="/random-domains/suggestions/reject" class="btn btn-secondary">Reject selected</button>
                <a href="/random-domains/suggestions?after={{after}}" class="btn btn-link">Next page</a>
            </td>
        </tr>
    </table>
        <input type="hidden" name="after" value="{{after}}" />
    </form>
    {{else}}
        <p><em>No pending suggestions.</em></p>
    {{/if}}
</div>

{{> control/partials/foot-includes }}
